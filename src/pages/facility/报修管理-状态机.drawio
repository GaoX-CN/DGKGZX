<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="drawio" version="26.0.0">
  <diagram name="报修管理-状态机" id="repair-statemachine">
    <mxGraphModel dx="1000" dy="1200" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1180" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="报修管理 · 状态机图 (State Machine)" style="text;html=1;align=left;verticalAlign=middle;fontSize=18;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="40" y="6" width="620" height="28" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="状态色：橙=待处理/审核类 · 蓝=核查中/待维修/方案 · 绿=已完成 · 红=方案已驳回 · 空心=维修中　｜　⚙ 框内为该状态可执行操作" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="36" width="1000" height="22" as="geometry" />
        </mxCell>

        <!-- Initial pseudostate -->
        <mxCell id="init" value="" style="ellipse;fillColor=#333333;strokeColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="502" y="74" width="36" height="36" as="geometry" />
        </mxCell>
        <mxCell id="initLbl" value="新建报修 / 巡检异常转报修" style="text;html=1;align=right;verticalAlign=middle;fontSize=10;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="295" y="80" width="195" height="28" as="geometry" />
        </mxCell>

        <!-- ===== Center column: main flow (top to bottom) ===== -->
        <mxCell id="s1" value="待处理&lt;br&gt;&lt;font size='9' color='#888888'&gt;pending_review&lt;/font&gt;&lt;br&gt;&lt;font size='10' color='#1a6fb0'&gt;核查 · 维修 · 编辑 · 删除&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#1a1a1a;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="415" y="122" width="210" height="72" as="geometry" />
        </mxCell>
        <mxCell id="s2" value="核查中&lt;br&gt;&lt;font size='9' color='#888888'&gt;checking&lt;/font&gt;&lt;br&gt;&lt;font size='10' color='#1a6fb0'&gt;仅详情（现场核查在核查工单中心）&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1a1a1a;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="415" y="238" width="210" height="72" as="geometry" />
        </mxCell>
        <mxCell id="s3" value="待提交方案&lt;br&gt;&lt;font size='9' color='#888888'&gt;approved&lt;/font&gt;&lt;br&gt;&lt;font size='10' color='#1a6fb0'&gt;提交方案&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1a1a1a;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="415" y="354" width="210" height="72" as="geometry" />
        </mxCell>
        <mxCell id="s4" value="方案待审核&lt;br&gt;&lt;font size='9' color='#888888'&gt;plan_pending&lt;/font&gt;&lt;br&gt;&lt;font size='10' color='#1a6fb0'&gt;审核方案&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#1a1a1a;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="415" y="470" width="210" height="72" as="geometry" />
        </mxCell>
        <mxCell id="s5" value="待维修&lt;br&gt;&lt;font size='9' color='#888888'&gt;plan_approved&lt;/font&gt;&lt;br&gt;&lt;font size='10' color='#1a6fb0'&gt;下发维修工单&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontColor=#1a1a1a;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="415" y="586" width="210" height="72" as="geometry" />
        </mxCell>
        <mxCell id="s6" value="维修中&lt;br&gt;&lt;font size='9' color='#888888'&gt;executing&lt;/font&gt;&lt;br&gt;&lt;font size='10' color='#1a6fb0'&gt;完成维修（系统工单中心）&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;dashed=1;fontColor=#1a1a1a;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="415" y="702" width="210" height="72" as="geometry" />
        </mxCell>
        <mxCell id="s7" value="待验收&lt;br&gt;&lt;font size='9' color='#888888'&gt;pending_acceptance&lt;/font&gt;&lt;br&gt;&lt;font size='10' color='#1a6fb0'&gt;验收（系统工单中心）&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontColor=#1a1a1a;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="415" y="818" width="210" height="72" as="geometry" />
        </mxCell>
        <mxCell id="s8" value="已完成&lt;br&gt;&lt;font size='9' color='#888888'&gt;completed&lt;/font&gt;&lt;br&gt;&lt;font size='10' color='#1a6fb0'&gt;仅详情&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontColor=#1a1a1a;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="415" y="934" width="210" height="72" as="geometry" />
        </mxCell>

        <!-- ===== Right terminal: 方案已驳回 ===== -->
        <mxCell id="s9" value="方案已驳回&lt;br&gt;&lt;font size='9' color='#888888'&gt;plan_rejected&lt;/font&gt;&lt;br&gt;&lt;font size='10' color='#1a6fb0'&gt;修改方案&lt;/font&gt;" style="rounded=1;arcSize=18;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontColor=#1a1a1a;fontSize=13;fontStyle=1;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="760" y="470" width="210" height="72" as="geometry" />
        </mxCell>

        <!-- ===== Transitions ===== -->
        <!-- initial -> s1 -->
        <mxCell id="e0" value="" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="init" target="s1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Main flow (vertical down through center) -->
        <mxCell id="e1" value="核查" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#333333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s1" target="s2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" value="需要维修" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#333333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s2" target="s3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" value="提交方案" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#333333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s3" target="s4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" value="审核通过" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#333333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s4" target="s5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" value="下发维修工单" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#333333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s5" target="s6">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" value="完成维修" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#333333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s6" target="s7">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e11" value="验收通过" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#333333;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="s7" target="s8">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- s1 -> s4 (维修：直接报修跳过核查) - far left corridor x=160 -->
        <mxCell id="eA" value="维修" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#6c8ebf;exitX=0;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s1" target="s4">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="160" y="158" />
              <mxPoint x="160" y="506" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- s2 -> s8 (已现场处置) - far right corridor x=1010 -->
        <mxCell id="eB" value="已现场处置" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#82b366;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s2" target="s8">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1010" y="274" />
              <mxPoint x="1010" y="970" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- s4 -> s9 (驳回) - right, horizontal -->
        <mxCell id="eRej" value="驳回" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#b85450;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s4" target="s9">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="700" y="506" />
            </Array>
          </mxGeometry>
        </mxCell>
        <!-- s9 -> s4 (修改方案) - back to review, route above -->
        <mxCell id="eMod" value="修改方案" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#b85450;exitX=0.5;exitY=0;entryX=1;entryY=0.25;" edge="1" parent="1" source="s9" target="s4">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="865" y="438" />
              <mxPoint x="692" y="438" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- s7 -> s5 (验收不通过 · 退回) - left corridor x=350 -->
        <mxCell id="eD" value="验收不通过 · 退回" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;fontSize=11;labelBackgroundColor=#ffffff;fontColor=#d79b00;exitX=0;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="s7" target="s5">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="350" y="854" />
              <mxPoint x="350" y="622" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Legend -->
        <mxCell id="legend" value="图例 Legend" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#666666;verticalAlign=top;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="80" y="1030" width="980" height="140" as="geometry" />
        </mxCell>
        <mxCell id="lg1" value="" style="rounded=1;arcSize=26;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;" vertex="1" parent="legend">
          <mxGeometry x="16" y="34" width="26" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lg1t" value="待处理 / 审核类 (橙)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="48" y="30" width="200" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lg2" value="" style="rounded=1;arcSize=26;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="legend">
          <mxGeometry x="16" y="58" width="26" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lg2t" value="核查中 / 待维修 / 方案 (蓝)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="48" y="54" width="220" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lg3" value="" style="rounded=1;arcSize=26;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="legend">
          <mxGeometry x="16" y="82" width="26" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lg3t" value="已完成 (绿)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="48" y="78" width="200" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lg4" value="" style="rounded=1;arcSize=26;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="legend">
          <mxGeometry x="290" y="34" width="26" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lg4t" value="方案已驳回 (红)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="322" y="30" width="200" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lg5" value="" style="rounded=1;arcSize=26;html=1;fillColor=#ffffff;strokeColor=#999999;dashed=1;" vertex="1" parent="legend">
          <mxGeometry x="290" y="58" width="26" height="16" as="geometry" />
        </mxCell>
        <mxCell id="lg5t" value="维修中 (空心，执行中)" style="text;html=1;align=left;verticalAlign=middle;fontSize=11;" vertex="1" parent="legend">
          <mxGeometry x="322" y="54" width="220" height="22" as="geometry" />
        </mxCell>
        <mxCell id="lgnote" value="说明：⚙ 状态框内为该状态可执行的业务操作；所有状态均支持【详情】。维修中/待验收的「完成维修」「验收」由系统工单中心驱动，本页报修列表对这两态仅显示【详情】。" style="text;html=1;align=left;verticalAlign=top;fontSize=10;fontColor=#666666;" vertex="1" parent="legend">
          <mxGeometry x="16" y="104" width="940" height="32" as="geometry" />
        </mxCell>
      </root>
