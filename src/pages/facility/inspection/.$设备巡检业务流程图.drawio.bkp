<mxfile host="app.diagrams.net" modified="2026-07-21T00:00:00.000Z" agent="OpenCode" version="26.0.0">
  <diagram id="equipment-inspection-business-flow" name="设备巡检业务流程图">
    <mxGraphModel dx="1920" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2400" pageHeight="1200" math="0" shadow="0" adaptiveColors="auto">
      <root>
        <mxCell id="0"/>
