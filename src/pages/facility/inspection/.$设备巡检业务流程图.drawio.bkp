        </mxCell>
        <mxCell id="lane3" value="巡检班组长" style="swimlane;horizontal=0;startSize=110;fillColor=#fff0e6;strokeColor=#d79b00;fontStyle=1;html=1;" vertex="1" parent="1">
          <mxGeometry x="0" y="300" width="2100" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="lane4" value="巡检人员" style="swimlane;horizontal=0;startSize=110;fillColor=#e8f5e9;strokeColor=#82b366;fontStyle=1;html=1;" vertex="1" parent="1">
          <mxGeometry x="0" y="450" width="2100" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="lane5" value="维修人员" style="swimlane;horizontal=0;startSize=110;fillColor=#fff9e6;strokeColor=#d6b656;fontStyle=1;html=1;" vertex="1" parent="1">
          <mxGeometry x="0" y="600" width="2100" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="start" value="巡检管理需求识别" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane1">
          <mxGeometry x="120" y="45" width="60" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="standard" value="制定巡检标准&#xa;明确检查方式与合格依据" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane1">
          <mxGeometry x="300" y="45" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="team" value="组建设备巡检班组&#xa;明确班组长与成员" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane1">
          <mxGeometry x="480" y="45" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="plan" value="制定并发布巡检计划&#xa;确定设备范围、周期和负责班组" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane1">
          <mxGeometry x="660" y="45" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="scheduled" value="在巡检时点&#xa;通知负责班组" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane2">
          <mxGeometry x="840" y="45" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="coordinate" value="统筹班组资源&#xa;安排人员承担巡检" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;" vertex="1" parent="lane3">
          <mxGeometry x="1020" y="45" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="accept" value="接受巡检任务&#xa;确认执行责任" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane4">
          <mxGeometry x="1200" y="45" width="140" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="inspect" value="现场逐台巡检&#xa;按标准评定每项结果" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane4">
          <mxGeometry x="1380" y="45" width="140" height="60" as="geometry"/>
        </mxCell>
