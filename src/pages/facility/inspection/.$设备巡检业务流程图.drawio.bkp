        </mxCell>
        <mxCell id="onsite" value="现场处理异常&#xa;说明处置情况" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="lane4">
