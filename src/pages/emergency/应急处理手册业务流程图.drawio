  <diagram id="emergency-manual-business-flow" name="应急处理手册业务流程"><mxGraphModel dx="1600" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1800" pageHeight="1000" math="0" shadow="0" adaptiveColors="auto"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="lane1" value="安全管理人员" style="swimlane;horizontal=0;startSize=110;fillColor=#f5f5f5;html=1;" vertex="1" parent="1"><mxGeometry x="0" y="0" width="1740" height="150" as="geometry"/></mxCell><mxCell id="lane2" value="责任部门" style="swimlane;horizontal=0;startSize=110;fillColor=#e8f4f8;html=1;" vertex="1" parent="1"><mxGeometry x="0" y="150" width="1740" height="150" as="geometry"/></mxCell><mxCell id="lane3" value="系统平台（辅助）" style="swimlane;horizontal=0;startSize=110;fillColor=#e8f5e9;html=1;" vertex="1" parent="1"><mxGeometry x="0" y="300" width="1740" height="150" as="geometry"/></mxCell><mxCell id="lane4" value="现场处置人员" style="swimlane;horizontal=0;startSize=110;fillColor=#fff9e6;html=1;" vertex="1" parent="1"><mxGeometry x="0" y="450" width="1740" height="150" as="geometry"/></mxCell><mxCell id="n1" value="识别手册新增或更新需求" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane1"><mxGeometry x="120" y="45" width="140" height="60" as="geometry"/></mxCell><mxCell id="n2" value="明确适用事件、区域和责任部门" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane1"><mxGeometry x="300" y="45" width="140" height="60" as="geometry"/></mxCell><mxCell id="n5" value="汇编手册内容并维护版本" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane1"><mxGeometry x="840" y="45" width="140" height="60" as="geometry"/></mxCell><mxCell id="n10" value="根据处置反馈修订手册和材料" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="lane1"><mxGeometry x="1380" y="45" width="140" height="60" as="geometry"/><